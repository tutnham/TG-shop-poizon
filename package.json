{
  "name": "poizon-shop",
  "private": true,
  "workspaces": ["apps/api", "apps/webapp", "packages/shared", "api"],
  "scripts": {
    "dev:api": "npm run dev -w @poizon-shop/api",
    "dev:webapp": "npm run dev -w @poizon-shop/webapp",
    "build": "npm run build -w @poizon-shop/shared && npm run build -w @poizon-shop/webapp",
    "build:api": "npm run build -w @poizon-shop/shared && npm run typecheck -w @poizon-shop/api",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "npm run test -w @poizon-shop/api"
  },
  "dependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
