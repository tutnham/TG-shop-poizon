{
  "name": "poizon-shop",
  "private": true,
  "workspaces": ["apps/api", "apps/webapp", "packages/shared", "api"],
  "scripts": {
    "dev:api": "npm run dev -w @poizon-shop/api",
    "dev:webapp": "npm run dev -w @poizon-shop/webapp",
    "build": "npm run build -w @poizon-shop/shared && npm run build -w @poizon-shop/webapp",
    "build:api": "npm run build -w @poizon-shop/shared && npm run typecheck -w @poizon-shop/api",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "npm run test -w @poizon-shop/api && npm run test -w @poizon-shop/webapp",
    "rates:update": "npm run rates:update -w @poizon-shop/api",
    "webhook:set": "npm run webhook:set -w @poizon-shop/api",
    "cron:webhooks": "npm run cron:webhooks -w @poizon-shop/api",
    "sync:poizon": "npm run sync:poizon -w @poizon-shop/api",
    "import:export3": "npm run import:export3 -w @poizon-shop/api",
    "purge:stale": "npm run purge:stale -w @poizon-shop/api",
    "purge:stale:dry": "npm run purge:stale:dry -w @poizon-shop/api"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "material-symbols": "^0.28.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
