{
  "buildCommand": "npm run build -w @poizon-shop/shared && npm run build -w @poizon-shop/webapp",
  "installCommand": "npm install",
  "outputDirectory": "apps/webapp/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/webhook/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" }
  ]
}
