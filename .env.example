# ── REQUIRED (production) ────────────────────────────────────────
# Без этих переменных приложение не запустится в production.

# Telegram Bots (получить у @BotFather)
SHOP_BOT_TOKEN=                # REQUIRED — токен клиентского бота
ADMIN_BOT_TOKEN=               # REQUIRED — токен админ-бота

# Webhook secret (≥32 chars в production, генерируется: openssl rand -hex 32)
WEBHOOK_SECRET=

# Supabase Cloud
SUPABASE_URL=https://xxxx.supabase.co    # REQUIRED — URL проекта (без /rest/v1/)
SUPABASE_SERVICE_ROLE_KEY=                # REQUIRED — service_role key (не anon!)

# URLs (после деплоя на Vercel)
WEBAPP_URL=https://your-project.vercel.app  # REQUIRED — URL Mini App
API_URL=https://your-project.vercel.app     # REQUIRED — URL API

# Vercel Cron secret (≥32 chars в production)
CRON_SECRET=

# ── REQUIRED (для провайдера Poizon) ─────────────────────────────
# Poizon провайдер: mock | poparce | official
# mock — локальная разработка без ключей
# poparce — сторонний DEWU API (нужен POIZON_API_KEY)
# official — Poizon-API/public-api (нужен POIZON_OFFICIAL_API_KEY)
POIZON_PROVIDER=mock
POIZON_API_KEY=                 # Ключ Poparce (только для POIZON_PROVIDER=poparce)
POIZON_API_BASE_URL=https://poparce.ru/api/dewu
POIZON_OFFICIAL_API_URL=https://poizon-api.com/api/dewu
POIZON_OFFICIAL_API_KEY=        # Ключ official API (только для POIZON_PROVIDER=official)

# ── OPTIONAL ─────────────────────────────────────────────────────

# Server
PORT=3000                       # Порт API сервера (только для локальной разработки)
DEMO_MODE=false                 # true — UI без Telegram (только для разработки)
NODE_ENV=development

# Supabase anon key (не используется сервером, может понадобиться клиенту)
SUPABASE_ANON_KEY=

# Курсы валют (fallback при недоступности ЦБ РФ / Binance)
CNY_TO_RUB_RATE=13.5
CNY_TO_USD_RATE=7.25

# Наценка и доставка
MARKUP_PERCENT=25               # Наценка в процентах
DELIVERY_RUB=0                  # Фиксированная доставка в рублях

# TON платежи (опционально, будущая фаза)
TON_WALLET_ADDRESS=
TON_RATE_USD=2.5

# Vercel Deployment Protection bypass
# Settings → Deployment Protection → Protection Bypass for Automation
VERCEL_AUTOMATION_BYPASS_SECRET=

# CORS (comma-separated origins, опционально)
CORS_ORIGINS=

# Image proxy allowed hosts (comma-separated, опционально для дополнительных хостов)
IMAGE_PROXY_ALLOWED_HOSTS=

# ── OPTIONAL: Pricing module ─────────────────────────────────────
# Продвинутая настройка модуля расчёта цен. Оставьте пустыми для дефолтов.

# Политика публичного курса: STRICT (ошибка при fallback) | ALLOW_FALLBACK
PRICING_PUBLIC_RATE_POLICY=
# Политика внутреннего USDT-курса: STRICT | ALLOW_FALLBACK
PRICING_INTERNAL_RATE_POLICY=
# Режим округления: ROUND_HALF_UP | ROUND_CEIL
PRICING_ROUNDING_MODE=
# Количество знаков после запятой при округлении (по умолчанию: 0)
PRICING_ROUNDING_SCALE=
# TTL кеша курса CNY→RUB в мс (по умолчанию: 86400000 = 24ч)
PRICING_CNY_RUB_TTL_MS=
# TTL кеша курса USDT→RUB в мс (по умолчанию: 300000 = 5мин)
PRICING_USDT_RUB_TTL_MS=
# Буфер волатильности USDT (доля, 0.03 = 3%)
PRICING_FX_BUFFER_PCT=
