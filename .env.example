# Telegram Bots
SHOP_BOT_TOKEN=
ADMIN_BOT_TOKEN=
WEBHOOK_SECRET=

# Server
PORT=3000
DEMO_MODE=false
NODE_ENV=development

# URLs (after Vercel deploy)
WEBAPP_URL=https://your-project.vercel.app
API_URL=https://your-project.vercel.app

# Vercel Deployment Protection bypass (if Bot Protection / checkpoint enabled)
# Settings → Deployment Protection → Protection Bypass for Automation
VERCEL_AUTOMATION_BYPASS_SECRET=

# Supabase Cloud
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Vercel Cron (rates refresh every hour)
CRON_SECRET=

# Poizon provider: mock | poparce | official
POIZON_PROVIDER=mock
POIZON_API_KEY=
POIZON_API_BASE_URL=https://poparce.ru/api/dewu
POIZON_OFFICIAL_API_URL=https://poizon-api.com/api/dewu
POIZON_OFFICIAL_API_KEY=

# Currency fallbacks (when CBR/Binance unavailable)
CNY_TO_RUB_RATE=13.5
CNY_TO_USD_RATE=7.25
MARKUP_PERCENT=25
DELIVERY_RUB=500

# TON payments (phase 4)
TON_WALLET_ADDRESS=
TON_RATE_USD=2.5

# CORS (comma-separated origins, optional)
CORS_ORIGINS=

# Image proxy allowed hosts (comma-separated, optional extra)
IMAGE_PROXY_ALLOWED_HOSTS=
