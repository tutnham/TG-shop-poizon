{
  "name": "@poizon-shop/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "start": "npx tsx src/index.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:migrate": "bun run scripts/migrate.ts",
    "webhook:set": "npx tsx scripts/webhook-set.ts",
    "rates:update": "npx tsx scripts/rates-update.ts",
    "sync:poizon": "npx tsx scripts/poizon-sync.ts",
    "import:pop2": "npx tsx scripts/import-pop2.ts",
    "delete:demo": "npx tsx scripts/delete-demo.ts",
    "fetch:prices": "npx tsx scripts/fetch-missing-prices.ts",
    "probe:poizon": "npx tsx scripts/probe-poizon-api.ts",
    "capture:poizon-har": "npx tsx scripts/capture-poizon-har.ts",
    "backfill:sizes": "npx tsx scripts/backfill-size-prices.ts",
    "backfill:sizes:loop": "npx tsx scripts/backfill-size-prices-loop.ts",
    "verify:size-prices": "npx tsx scripts/verify-size-prices.ts",
    "backfill:shihuo-prices": "npx tsx scripts/backfill-shihuo-prices.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@poizon-shop/shared": "file:../../packages/shared",
    "@supabase/supabase-js": "^2.47.10",
    "decimal.js": "^10.6.0",
    "grammy": "^1.35.0",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
